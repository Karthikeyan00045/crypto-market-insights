                    </story-point>
                    <story-point caption='“Portfolio concentration risk under equal allocation&quot;' captured-sheet='Scenario Analysis: Portfolio Value by Cryptocurrency' id='10'>
                      <capturedDeltas>
                        <worksheet name='Scenario Analysis: Portfolio Value by Cryptocurrency'>
                          <annotations>
                            <annotation class='point' delta-type='edited' id='9' mark-position='1' pullback='12' text-width='148'>
                              <formatted-text>
                                <run fontalignment='1' fontcolor='#ff0000' fontname='Calibri'>crypto group: </run>
                                <run bold='true' fontalignment='1' fontcolor='#ff0000' fontname='Calibri'><![CDATA[<[federated.1rlylfb1pa6vvj12rw9yh059aoah].[none:Calculation_0392030326333440:nk]>]]></run>
