            <zone h='90239' id='1' param='vert' removable='false' type-v2='layout-flow' w='98324' x='838' y='8391'>
              <zone h='17295' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98324' x='838' y='8391' />
              <zone h='72944' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98324' x='838' y='25686'>
                <flipboard active-id='7' nav-type='caption' show-nav-arrows='true'>
                  <story-points>
                    <story-point caption='“Comparing scale and liquidity dynamics in crypto markets &quot;' captured-sheet='- Market Cap Dominance' id='7'>
                      <capturedDeltas>
                        <worksheet name='- Market Cap Dominance'>
                          <annotations>
                            <annotation class='area' delta-type='edited' id='2' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                              <formatted-text>
                                <run fontcolor='#000000' fontname='Tableau Medium' fontsize='12'>Bitcoin alone accounts for nearly two-thirds of total crypto capitalization, underscoring its dominance and concentration risk. Ethereum provides balance as the second-largest asset, while stablecoins like Tether and USDC dominate liquidity rather than capitalization. This dual perspective highlights the tension between scale and utility in crypto markets.</run>
                              </formatted-text>
                              <top-left>
                                <visual-coordinate class='axis'>
                                  <x-coord axis-value='227765023255.81393'>
                                    <node-reference>
                                      <axis>[federated.1rlylfb1pa6vvj12rw9yh059aoah].[sum:market_cap_usd:qk]</axis>
                                    </node-reference>
                                  </x-coord>
                                  <y-coord cell-offset='0.243243'>
                                    <node-reference>
                                      <fields>
                                        <field>[federated.1rlylfb1pa6vvj12rw9yh059aoah].[none:name:nk]</field>
                                      </fields>
                                      <multibucket>
                                        <bucket>&quot;BNB&quot;</bucket>
                                      </multibucket>
                                    </node-reference>
                                  </y-coord>
                                  <page-reference />
                                </visual-coordinate>
                              </top-left>
                              <bottom-right>
                                <visual-coordinate class='axis'>
                                  <x-coord axis-value='1127084651162.7908'>
                                    <node-reference>
                                      <axis>[federated.1rlylfb1pa6vvj12rw9yh059aoah].[sum:market_cap_usd:qk]</axis>
                                    </node-reference>
                                  </x-coord>
                                  <y-coord cell-offset='0.558559'>
                                    <node-reference>
                                      <fields>
                                        <field>[federated.1rlylfb1pa6vvj12rw9yh059aoah].[none:name:nk]</field>
                                      </fields>
                                      <multibucket>
                                        <bucket>&quot;Dogecoin&quot;</bucket>
                                      </multibucket>
                                    </node-reference>
                                  </y-coord>
                                  <page-reference />
                                </visual-coordinate>
                              </bottom-right>
                              <text x='0.5' y='0.5' />
                            </annotation>
                          </annotations>
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='“Value vs. utility trade-offs across assets&quot;' captured-sheet='- Price vs Volume' id='8'>
                      <capturedDeltas>
                        <worksheet name='- Price vs Volume'>
                          <annotations>
                            <annotation class='area' delta-type='edited' id='0' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                              <formatted-text>
                                <run fontalignment='0' fontcolor='#000000' fontname='Tableau Medium' fontsize='12'>The scatter plot reveals the relationship between price, trading volume, and market capitalization. Bitcoin dominates across all three dimensions, while stablecoins such as Tether and USDC demonstrate outsized liquidity despite low prices. This duality highlights the tension between speculative value and transactional utility in crypto markets.</run>
                              </formatted-text>
                              <top-left>
                                <visual-coordinate class='axis'>
                                  <x-coord axis-value='5373.4846646293863'>
                                    <node-reference>
                                      <axis>[federated.1rlylfb1pa6vvj12rw9yh059aoah].[sum:price_usd:qk]</axis>
                                    </node-reference>
                                  </x-coord>
                                  <y-coord axis-value='40787340127.009377'>
