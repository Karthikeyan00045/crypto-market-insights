            <column caption='crypto group' datatype='string' name='[Calculation_0392030326333440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [name] = &quot;Ethereum&quot; OR [name] = &quot;Tether USDt&quot; THEN &quot;Balance Providers&quot;&#13;&#10;ELSEIF [name] IN (&quot;Solana&quot;,&quot;BNB&quot;,&quot;Dogecoin&quot;,&quot;TRON&quot;,&quot;USDC&quot;,&quot;XRP&quot;,&quot;Hyperliquid&quot;) THEN &quot;Others&quot;&#13;&#10;ELSEIF [name] = &quot;Bitcoin&quot; THEN &quot;Dominant&quot;&#13;&#10;END' />
            </column>
            <column caption='portfolio value' datatype='real' name='[Calculation_1215564393955333]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[market_cap_usd] * ([Parameters].[Parameter 1] / 100)' />
            </column>
            <column caption='Market Cap Usd' datatype='real' name='[market_cap_usd]' role='measure' type='quantitative' />
