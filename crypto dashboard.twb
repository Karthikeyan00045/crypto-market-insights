          <formatted-text>
            <run bold='true' fontalignment='1' fontname='Tableau Medium'>Scenario Analysis Chart</run>
            <run fontalignment='1' fontname='Tableau Medium' fontsize='11'>Æ&#10;</run>
            <run fontalignment='1' fontname='Tableau Medium' fontsize='12' italic='true'>“Portfolio concentration risk under equal allocation&quot;</run>
          </formatted-text>
        </title>
