                              <text x='0.5' y='0.5' />
                            </annotation>
                          </annotations>
                        </worksheet>
                      </capturedDeltas>
                    </story-point>
                    <story-point caption='“Scarcity and issuance maturity across major cryptocurrencies&quot;' captured-sheet='Supply Ratio' id='9'>
                      <capturedDeltas>
                        <worksheet name='Supply Ratio'>
                          <annotations>
                            <annotation class='area' delta-type='edited' id='0' text-pinx='0.5' text-piny='0.5' text-width-delta='-18'>
                              <formatted-text>
                                <run fontalignment='0' fontcolor='#000000' fontname='Tableau Medium'>Supply ratios reveal the maturity of issuance across cryptocurrencies. Bitcoin and BNB are nearly fully issued, underscoring scarcity-driven value. In contrast, Hyperliquid remains early-stage, while XRP sits mid-range. This perspective highlights how scarcity and issuance maturity shape market positioning.</run>
                              </formatted-text>
