      <size maxheight='584' maxwidth='955' minheight='584' minwidth='955' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97260' id='7' param='vert' removable='false' type-v2='layout-flow' w='98324' x='838' y='1370'>
            <zone h='7021' id='8' type-v2='title' w='98324' x='838' y='1370'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
